{
  "name": "skill-organizer-extension",
  "displayName": "Skill Organizer",
  "description": "Import and manage reusable AI skills from GitHub repos, skills.sh URLs, and local folders.",
  "version": "0.0.19",
  "publisher": "unthinkmedia",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/unthinkmedia/skill_organizer.git"
  },
  "homepage": "https://github.com/unthinkmedia/skill_organizer/tree/main/skill-organizer-extension",
  "bugs": {
    "url": "https://github.com/unthinkmedia/skill_organizer/issues"
  },
  "keywords": [
    "vscode",
    "extension",
    "skills",
    "github",
    "copilot",
    "ai",
    "instructions",
    "custom-instructions",
    "agents"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "icon": "media/icon-128.png",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillOrganizer",
          "title": "Skill Organizer",
          "icon": "media/skill-organizer.svg"
        }
      ]
    },
    "views": {
      "skillOrganizer": [
        {
          "id": "skillOrganizer.sources",
          "name": "External Sources"
        },
        {
          "id": "skillOrganizer.activeSkills",
          "name": "Active Skills"
        },
        {
          "id": "skillOrganizer.enabledGlobally",
          "name": "Global Skills"
        }
      ]
    },
    "commands": [
      {
        "command": "skillOrganizer.addSource",
        "title": "Add Source",
        "category": "Skill Organizer",
        "icon": "$(add)"
      },
      {
        "command": "skillOrganizer.addGitHubSource",
        "title": "Add GitHub Source",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.addFromSkillsSh",
        "title": "Add from skills.sh URL",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.chooseGitHubAccount",
        "title": "Switch GitHub Account",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.removeSource",
        "title": "Remove Source",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.refresh",
        "title": "Refresh Sources",
        "category": "Skill Organizer",
        "icon": "$(refresh)"
      },
      {
        "command": "skillOrganizer.toggleSkill",
        "title": "Enable or Disable Skill",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.freezeSkill",
        "title": "Freeze Skill",
        "category": "Skill Organizer",
        "icon": "$(lock)"
      },
      {
        "command": "skillOrganizer.unfreezeSkill",
        "title": "Unlock Skill",
        "category": "Skill Organizer",
        "icon": "$(unlock)"
      },
      {
        "command": "skillOrganizer.removeFromWorkspace",
        "title": "Remove from Workspace Enabled",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.removeFromGlobalDefaults",
        "title": "Remove from Global Defaults",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.setGlobalDefault",
        "title": "Toggle Global Default",
        "category": "Skill Organizer",
        "icon": {
          "light": "media/star-outline-light.svg",
          "dark": "media/star-outline-dark.svg"
        }
      },
      {
        "command": "skillOrganizer.unsetGlobalDefault",
        "title": "Toggle Global Default",
        "category": "Skill Organizer",
        "icon": {
          "light": "media/star-light.svg",
          "dark": "media/star-dark.svg"
        }
      },
      {
        "command": "skillOrganizer.syncWorkspaceSkills",
        "title": "Resync Managed Skills",
        "category": "Skill Organizer",
        "icon": "$(sync)"
      },
      {
        "command": "skillOrganizer.markManual",
        "title": "Detach from Source",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.markManaged",
        "title": "Reconnect to Source",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.uninstallSkill",
        "title": "Remove Local Skill",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.updateManagedSkill",
        "title": "Update Managed Skill",
        "category": "Skill Organizer",
        "icon": "$(refresh)"
      },
      {
        "command": "skillOrganizer.explainMissingSkill",
        "title": "Resolve Missing Skill",
        "category": "Skill Organizer",
        "icon": {
          "light": "media/lightbulb-light.svg",
          "dark": "media/lightbulb-dark.svg"
        }
      },
      {
        "command": "skillOrganizer.extendAgents",
        "title": "Review AGENTS.md with Copilot",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.explainConflict",
        "title": "Explain Conflict",
        "category": "Skill Organizer"
      },
      {
        "command": "skillOrganizer.searchSkills",
        "title": "Search Skills",
        "category": "Skill Organizer",
        "icon": "$(search)"
      },
      {
        "command": "skillOrganizer.submitSkillPR",
        "title": "Submit Skill as PR",
        "category": "Skill Organizer",
        "icon": "$(git-pull-request-create)"
      }
    ],
    "configuration": {
      "title": "Skill Organizer",
      "properties": {
        "skillOrganizer.destinationPath": {
          "type": "string",
          "default": ".github/skills",
          "description": "Workspace-relative path where enabled skills are copied as local skills."
        },
        "skillOrganizer.globalDestinationPath": {
          "type": "string",
          "default": "~/.agents/skills",
          "description": "Path where global default skills are copied as user-level (personal) skills, available in all workspaces. Supports ~ for home directory."
        },
        "skillOrganizer.materializationMode": {
          "type": "string",
          "enum": [
            "copy"
          ],
          "default": "copy",
          "description": "How skills are copied into local workspace folders. Currently supports copy mode only."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "skillOrganizer.addSource",
          "when": "view == skillOrganizer.sources",
          "group": "navigation"
        },
        {
          "command": "skillOrganizer.searchSkills",
          "when": "view == skillOrganizer.sources",
          "group": "navigation"
        },
        {
          "command": "skillOrganizer.chooseGitHubAccount",
          "when": "view == skillOrganizer.sources",
          "group": "2_sources@1"
        },
        {
          "command": "skillOrganizer.refresh",
          "when": "view == skillOrganizer.sources",
          "group": "2_sources@2"
        },
        {
          "command": "skillOrganizer.syncWorkspaceSkills",
          "when": "view == skillOrganizer.activeSkills",
          "group": "3_workspace@1"
        },
        {
          "command": "skillOrganizer.extendAgents",
          "when": "view == skillOrganizer.sources",
          "group": "4_governance@1"
        }
      ],
      "view/item/context": [
        {
          "command": "skillOrganizer.refresh",
          "when": "view == skillOrganizer.sources && viewItem == sectionItem_sources",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.refresh",
          "when": "view == skillOrganizer.sources && viewItem == sourceItem",
          "group": "inline@1"
        },
        {
          "command": "skillOrganizer.removeSource",
          "when": "view == skillOrganizer.sources && viewItem == sourceItem",
          "group": "3_danger@1"
        },
        {
          "command": "skillOrganizer.syncWorkspaceSkills",
          "when": "view == skillOrganizer.activeSkills && viewItem == sectionItem_materialized",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.setGlobalDefault",
          "when": "view == skillOrganizer.sources && viewItem == sourceSkillItem",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.unsetGlobalDefault",
          "when": "view == skillOrganizer.sources && viewItem == sourceSkillItemGlobal",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.unfreezeSkill",
          "when": "view == skillOrganizer.sources && viewItem == sourceSkillItemFrozen",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.freezeSkill",
          "when": "view == skillOrganizer.sources && viewItem == sourceSkillItem",
          "group": "navigation"
        },
        {
          "command": "skillOrganizer.setGlobalDefault",
          "when": "view == skillOrganizer.sources && viewItem == sourceSkillItem",
          "group": "navigation"
        },
        {
          "command": "skillOrganizer.setGlobalDefault",
          "when": "view == skillOrganizer.sources && viewItem == workspaceSkillItem",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.removeFromWorkspace",
          "when": "view == skillOrganizer.sources && viewItem == workspaceSkillItem",
          "group": "3_danger@1"
        },
        {
          "command": "skillOrganizer.unsetGlobalDefault",
          "when": "view == skillOrganizer.sources && viewItem == workspaceSkillItemGlobal",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.removeFromWorkspace",
          "when": "view == skillOrganizer.sources && viewItem == workspaceSkillItemGlobal",
          "group": "3_danger@1"
        },
        {
          "command": "skillOrganizer.removeFromGlobalDefaults",
          "when": "view == skillOrganizer.enabledGlobally && viewItem == globalSkillItem",
          "group": "3_danger@1"
        },
        {
          "command": "skillOrganizer.explainMissingSkill",
          "when": "viewItem == missingWorkspaceSkillItem || viewItem == missingGlobalSkillItem",
          "group": "inline"
        },
        {
          "command": "skillOrganizer.updateManagedSkill",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManagedSkillItem",
          "group": "inline@1"
        },
        {
          "command": "skillOrganizer.updateManagedSkill",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManagedSkillItemGlobal",
          "group": "inline@1"
        },
        {
          "command": "skillOrganizer.setGlobalDefault",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManagedSkillItem",
          "group": "inline@2"
        },
        {
          "command": "skillOrganizer.unsetGlobalDefault",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManagedSkillItemGlobal",
          "group": "inline@2"
        },
        {
          "command": "skillOrganizer.setGlobalDefault",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManualSkillItemReconnectable",
          "group": "inline@2"
        },
        {
          "command": "skillOrganizer.unsetGlobalDefault",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManualSkillItemReconnectableGlobal",
          "group": "inline@2"
        },
        {
          "command": "skillOrganizer.markManual",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManagedSkillItem",
          "group": "navigation"
        },
        {
          "command": "skillOrganizer.markManaged",
          "when": "view == skillOrganizer.activeSkills && viewItem == materializedManualSkillItem",
          "group": "navigation"
        },
        {
          "command": "skillOrganizer.uninstallSkill",
          "when": "view == skillOrganizer.activeSkills && (viewItem == materializedManagedSkillItem || viewItem == materializedManualSkillItem)",
          "group": "3_danger@1"
        },
        {
          "command": "skillOrganizer.submitSkillPR",
          "when": "view == skillOrganizer.activeSkills && (viewItem == materializedManagedSkillItem || viewItem == materializedManualSkillItem)",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "skillOrganizer.addGitHubSource",
          "when": "false"
        },
        {
          "command": "skillOrganizer.addFromSkillsSh",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "skillOrganizer.sources",
        "contents": "No sources configured yet. [Add your first source](command:skillOrganizer.addSource)"
      },
      {
        "view": "skillOrganizer.sources",
        "contents": "Use the ··· menu for source refresh, global skill sync, and workspace sync."
      }
    ]
  },
  "scripts": {
    "sync:readme": "node -e \"const fs=require('fs');let s=fs.readFileSync('../README.md','utf8');s=s.replaceAll('./skill-organizer-extension/media/','https://raw.githubusercontent.com/unthinkmedia/skill_organizer/main/skill-organizer-extension/media/');fs.writeFileSync('./README.md',s);\"",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run sync:readme && npm run compile",
    "package": "npx @vscode/vsce package",
    "publish:patch": "npx @vscode/vsce publish patch"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.2"
  }
}
